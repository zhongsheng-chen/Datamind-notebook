# .env 文件 - 环境变量配置

# 镜像构建配置
BUILD_TYPE=production  # development, testing, production
IMAGE_NAME=datamind-notebook
IMAGE_TAG=latest
CONTAINER_NAME=datamind-notebook

# 用户配置
NB_USER=jovyan
NB_UID=1000
NB_GID=1000
GRANT_SUDO=no

# 端口配置
PORT=8888

# 目录挂载配置
WORKSPACE_DIR=./workspace
DATA_DIR=./data
JUPYTER_CONFIG_DIR=./jupyter

# Jupyter配置
JUPYTER_PASSWORD=''  # 设置后会自动配置密码
JUPYTER_TOKEN=''     # 或使用令牌

# 资源限制
CPU_LIMIT=2
CPU_RESERVATION=0.5
MEMORY_LIMIT=4G
MEMORY_RESERVATION=1G

# 日志配置
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3

# 网络配置
NETWORK_NAME=datamind-notebook-network 
NETWORK_SUBNET=172.29.0.0/16
NETWORK_GATEWAY=172.29.0.1
IPV4_ADDRESS=172.29.0.2
VOLUME_PREFIX=datamind-notebook

# 重启策略
RESTART_POLICY=unless-stopped

# pip镜像配置
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
PIP_EXTRA_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/

# 构建选项
EXTRA_APT_PACKAGES=
CLEAN_BUILD_DEPS=true
INSTALL_DEV_TOOLS=false