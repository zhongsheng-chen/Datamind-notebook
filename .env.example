# 基础配置
TAG=latest
TZ=Asia/Shanghai

# 用户配置
NB_USER=jovyan
NB_UID=1000
NB_GID=1000

# 端口配置
PORT=8888


# Jupyter Token 配置
JUPYTER_TOKEN=your-secure-token-here

# 镜像源配置（国内用户推荐使用清华源）
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
# PIP_EXTRA_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/

# 构建配置
EXTRA_APT_PACKAGES=
INSTALL_DEV_TOOLS=false
CLEAN_BUILD_DEPS=true

# 资源限制
CPU_LIMIT=2
MEMORY_LIMIT=4G
CPU_RESERVATION=0.5
MEMORY_RESERVATION=1G